{
  "compilerOptions": {
    "target": "ES5",
    "module": "commonjs",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "allowJs": true,
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["app.ts", "./src/**/*.ts"],
  "exclude": ["node_modules"]
}
